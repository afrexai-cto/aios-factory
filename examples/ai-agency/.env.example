# Environment Variables — AI Automation Agency
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── AI Service ──────────────────────────────────────────────
# Required for proposal generation, scoping assistance, and analysis.

# Anthropic Claude API (recommended for AIOS builds)
ANTHROPIC_API_KEY=

# OpenAI API (alternative or supplementary)
# OPENAI_API_KEY=

# ─── Communication ───────────────────────────────────────────
# Slack integration for team and client communication.

# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_TEAM_ID=T0000000000

# ─── Project Management ─────────────────────────────────────
# Notion for tracking projects, clients, and pipeline.

# NOTION_TOKEN=secret_your-token
# NOTION_DATABASE_ID=your-database-id

# ─── Calendar ────────────────────────────────────────────────
# Google Calendar for discovery calls and project milestones.

# GOOGLE_CREDENTIALS=path/to/credentials.json

# ─── Email ───────────────────────────────────────────────────
# For sending proposals and invoices.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@youragency.com
# SMTP_PASS=app-password
